---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="tr">
  <head>
    <BaseHead
      title="Veri Atlası · Furkan Başoğlu"
      description="RF / sinyal analiz araçları — CSV, S-parametre, IQ, dalga formu."
    />
    <style>
      html, body { margin: 0; padding: 0; height: 100%; background: #0f0f0f; }
      .container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        overflow: hidden;
      }
      .info-bar {
        padding: 0.5rem 1.5rem;
        background: #181818;
        border-bottom: 1px solid #2a2a2a;
        font-size: 0.85rem;
        color: #aaa;
        text-align: center;
        flex-shrink: 0;
      }
      .info-bar a {
        color: #7eb8f7;
        text-decoration: none;
      }
      .info-bar a:hover {
        color: #acd4ff;
        text-decoration: underline;
      }
      .frame {
        flex: 1;
        border: none;
        width: 100%;
        display: block;
        background: #0f0f0f;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <Header />
      <div class="info-bar">
        Bu araçla ilgili bir sorun yaşar veya öneri iletmek istersen
        <a href="/iletisim">İletişim</a> sayfasından yazabilirsin.
      </div>
      <iframe class="frame" src="/veri_atlasi/index.html" title="Veri Atlası" loading="eager"></iframe>
    </div>
  </body>
</html>
